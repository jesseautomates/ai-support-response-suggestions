        "jsCode": "const all = $input.all();\n\nconst total = all.length;\nconst human = all.filter(i => i.json.review_status === 'Human Review Required').length;\nconst auto = all.filter(i => i.json.review_status === 'Ready for Agent Use').length;\n\nreturn [\n  {\n    json: {\n      total_tickets: total,\n      human_review_count: human,\n      auto_processed_count: auto,\n      automation_rate: total ? auto / total : 0\n    }\n  }\n];"
