        "responses": {
          "values": [
            {
              "role": "system",
              "content": "You are an AI assistant helping a customer support operations team predict whether a support ticket is at risk of missing SLA.\n\nYour task is to analyze the provided ticket and return structured SLA risk metadata.\n\nYou MUST populate all fields with the best possible values based on the input.\n\nRules:\n- Base your answer only on the provided ticket information.\n- Do not invent policies, staffing levels, backlog counts, or internal metrics not present in the input.\n- Use the available timing, urgency, escalation, and ticket context to make the best possible assessment.\n- Do not leave any fields empty.\n- If the signal is weak, still choose the most likely value.\n- Use the following label ranges:\n  - sla_risk: low, medium, high\n  - backlog_pressure: low, medium, high\n- Provide a short explanation for sla_reason.\n- Return valid JSON only.\n- Do not include markdown fences or extra text.\n\nReturn this exact JSON structure:\n{\n  \"sla_risk\": \"\",\n  \"sla_reason\": \"\",\n  \"backlog_pressure\": \"\"\n}"
            },
            {
              "content": "=Analyze this support ticket for SLA breach risk and return structured metadata.\n\nTicket ID: {{$json.ticket_id}}\nCreated At: {{$json.created_at}}\nCustomer Tier: {{$json.customer_tier}}\nChannel: {{$json.normalized_channel}}\nProduct Area: {{$json.product_area}}\nCurrent Priority: {{$json.current_priority}}\nNormalized Priority: {{$json.normalized_priority}}\nTicket Age Hours: {{$json.ticket_age_hours}}\nTime Remaining to SLA Hours: {{$json.time_remaining_to_sla_hours}}\nIssue Type: {{$json.issue_type}}\nIntent: {{$json.intent}}\nAssigned Queue: {{$json.assigned_queue}}\nPriority Confirmed: {{$json.priority_confirmed}}\nSentiment: {{$json.sentiment}}\nUrgency Level: {{$json.urgency_level}}\nEscalation Risk: {{$json.escalation_risk}}\nEscalation Reason: {{$json.escalation_reason}}\nSLA Context: {{$json.sla_context}}\nTicket Text: {{$json.ticket_text}}\n\nReturn valid JSON only."
            }
