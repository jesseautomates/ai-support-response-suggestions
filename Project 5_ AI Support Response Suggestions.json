        "jsCode": "const escalationRisk = ($json.escalation_risk || '').toLowerCase();\nconst slaRisk = ($json.sla_risk || '').toLowerCase();\nconst confidence = ($json.confidence || '').toLowerCase();\nconst customerTier = ($json.customer_tier || '').toLowerCase();\n\nconst needsHumanReview =\n  escalationRisk === 'high' ||\n  slaRisk === 'high' ||\n  confidence === 'low';\n\nconst reviewReason =\n  escalationRisk === 'high'\n    ? 'High escalation risk'\n    : slaRisk === 'high'\n    ? 'High SLA risk'\n    : confidence === 'low'\n    ? 'Low AI confidence'\n    : 'No review required';\n\nreturn {\n  json: {\n    ...$json,\n    needs_human_review: needsHumanReview,\n    review_reason: reviewReason\n  }\n};"
